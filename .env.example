# ===========================================
# DropTrack Backend Environment Configuration
# ===========================================
# Copy this file to .env and configure for your environment
# For production, ensure ALL required values are set
#
# ⚠️  NEVER COMMIT .env WITH REAL CREDENTIALS TO GIT
# ⚠️  USE SECRETS MANAGER FOR PRODUCTION DEPLOYMENTS

# ===========================================
# ENVIRONMENT (REQUIRED)
# ===========================================
# Options: development, production
# WARNING: Leaving this unset on Linux defaults to 'production'
ENVIRONMENT=development

# ===========================================
# DEBUG MODE (REQUIRED IN PRODUCTION)
# ===========================================
# Set to false in production - enables strict JWT validation
# WARNING: debug=true disables audience/issuer JWT checks!
DEBUG=true

# PostgreSQL connection string with PostGIS support
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://droptrack_user:droptrack_2026@localhost:5432/droptrack_db

# ===========================================
# AWS COGNITO AUTHENTICATION (REQUIRED)
# ===========================================
# Get these from AWS Cognito Console
COGNITO_REGION=ap-southeast-2
COGNITO_USER_POOL_ID=ap-southeast-2_oD2jN0YmE
COGNITO_APP_CLIENT_ID=5kimn5c022q53kuvmhr71mu2tl
COGNITO_CLIENT_SECRET=1qgkrkchr3h6dpbr49d14ho0c56n7n6hgark37jhntn5msb92j1c

# ===========================================
# STRIPE PAYMENT PROCESSING (REQUIRED)
# ===========================================
# Get these from Stripe Dashboard
# Use sk_test_xxx and whsec_xxx for development
# Use sk_live_xxx and whsec_xxx for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Payment redirect URLs (customize for your frontend)
PAYMENT_SUCCESS_URL=http://localhost:5173/client/payment/success
PAYMENT_CANCEL_URL=http://localhost:5173/client/payment/cancel

# ===========================================
# SECURITY (REQUIRED)
# ===========================================
# Generate a secure key with: 
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be at least 32 characters for production
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars

# JWT Algorithm (usually HS256)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# CORS ORIGINS (REQUIRED IN PRODUCTION)
# ===========================================
# Comma-separated list of allowed origins
# In production: only your actual domains (NO localhost!)
# In development: can include localhost
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# API CONFIGURATION (OPTIONAL)
# ===========================================
API_V1_PREFIX=/api/v1

# ===========================================
# SUPERADMIN CONFIGURATION (OPTIONAL)
# ===========================================
# Comma-separated list of superadmin email addresses
# These users automatically get admin privileges
# Use SUPERADMIN_EMAILS env var instead of individual accounts
SUPERADMIN_EMAILS=admin@yourdomain.com

# Legacy individual superadmin config (deprecated)
# SUPERADMIN_1_EMAIL=admin@example.com
# SUPERADMIN_1_PASSWORD=   # ⚠️ NEVER store passwords in files!
# SUPERADMIN_2_EMAIL=admin2@example.com
# SUPERADMIN_2_PASSWORD=   # ⚠️ Use AWS Secrets Manager instead

# ===========================================
# SERVER CONFIGURATION (OPTIONAL)
# ===========================================
# Defaults: HOST=0.0.0.0 (Linux) / 127.0.0.1 (Windows)
#           PORT=8000, WORKERS=4 (production only)
# HOST=0.0.0.0
# PORT=8000
# WORKERS=4

# ===========================================
# LOGGING (OPTIONAL)
# ===========================================
# Set LOG_DIR to enable file-based logging
# LOG_DIR=/var/log/droptrack
# LOG_FORMAT=json  # Use 'json' for structured logging in production

# ===========================================
# BACKGROUND JOBS (OPTIONAL)
# ===========================================
# Enable cleanup job outside production
# Cleanup runs daily at 2 AM UTC
# ENABLE_CLEANUP_JOB=true

# ===========================================
# TESTING (INTERNAL USE)
# ===========================================
# Set to 1 to disable TrustedHostMiddleware during tests
# TESTING=0