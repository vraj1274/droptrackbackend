###############################################
# DropVerify Backend - Environment Variables  #
###############################################

# PostgreSQL connection
# PRODUCTION: Must use production database (not localhost)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/droptrack

# Runtime mode
# PRODUCTION: Must be "production"
ENVIRONMENT=development
# PRODUCTION: Must be "false"
DEBUG=true

# Security
# PRODUCTION: Must be a strong random string (at least 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-generate-a-strong-random-value

# CORS origins (comma separated)
# PRODUCTION: Must NOT include localhost. Only production domains.
# Example: https://droptrack.com.au,https://www.droptrack.com.au
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AWS Cognito Configuration
# PRODUCTION: Must use production Cognito User Pool (not test)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_your_user_pool_id
COGNITO_APP_CLIENT_ID=your_app_client_id

# Stripe Configuration
# PRODUCTION: Must use live keys (sk_live_...)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Superadmin Configuration (comma separated list of emails)
# PRODUCTION: Set to actual admin emails
SUPERADMIN_EMails=admin@example.com,info@example.com

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Logging (optional)
# LOG_FORMAT=json  # Use "json" for structured logging in production
# LOG_DIR=/var/log/droptrack  # Directory for log files (optional)






